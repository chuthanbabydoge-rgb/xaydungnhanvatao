# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_companion
REDIS_URL=redis://localhost:6379
MONGODB_URL=mongodb://admin:admin@localhost:27017
QDRANT_URL=http://localhost:6333
NEO4J_URL=bolt://localhost:7687
RABBITMQ_URL=amqp://admin:admin@localhost:5672

# Service Ports
LLM_SERVICE_PORT=8001
MEMORY_SERVICE_PORT=8002
CONVERSATION_SERVICE_PORT=8003
EMOTION_SERVICE_PORT=8004
MOTIVATION_SERVICE_PORT=8005
REFLECTION_SERVICE_PORT=8006
LEARNING_SERVICE_PORT=8007
PLUGIN_SERVICE_PORT=8008
SCHEDULER_SERVICE_PORT=8009
VISION_MEMORY_SERVICE_PORT=8010
AUTH_SERVICE_PORT=8011
USER_SERVICE_PORT=8012
ASSET_SERVICE_PORT=8013
WORLD_SERVICE_PORT=8014
PHYSICS_SERVICE_PORT=8015
CHARACTER_SERVICE_PORT=8016
ANIMATION_SERVICE_PORT=8017
VISION_SERVICE_PORT=8018
STT_SERVICE_PORT=8019
TTS_SERVICE_PORT=8020
SOCIAL_SERVICE_PORT=8021
MULTI_AGENT_SERVICE_PORT=8022

# LLM Configuration
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
COHERE_API_KEY=your_cohere_api_key
HUGGINGFACE_API_KEY=your_huggingface_api_key

# Speech Services
ELEVENLABS_API_KEY=your_elevenlabs_api_key
WHISPER_MODEL=base

# Security
JWT_SECRET_KEY=your_jwt_secret_key
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Environment
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO

# Monitoring
SENTRY_DSN=your_sentry_dsn
PROMETHEUS_ENABLED=True
