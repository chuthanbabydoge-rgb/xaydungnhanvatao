# Application
APP_NAME=LLM Service
APP_VERSION=0.1.0
DEBUG=false
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8002
WORKERS=4

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/llm_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600
REDIS_MAX_CONNECTIONS=50

# OpenAI
OPENAI_API_KEY=
OPENAI_ORG_ID=
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Google
GOOGLE_API_KEY=
GOOGLE_PROJECT_ID=

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Local LLM
LOCAL_LLM_PATH=
LOCAL_LLM_DEVICE=cuda
LOCAL_LLM_QUANTIZE=true
LOCAL_LLM_GPTQ=false

# Model Configuration
DEFAULT_MODEL=gpt-4-turbo-preview
DEFAULT_MODEL_MAX_TOKENS=4096
DEFAULT_MODEL_TEMPERATURE=0.7
DEFAULT_MODEL_TOP_P=0.9
DEFAULT_MODEL_FREQUENCY_PENALTY=0.0
DEFAULT_MODEL_PRESENCE_PENALTY=0.0

# Model Selection
ENABLE_MODEL_ROUTING=true
ROUTING_STRATEGY=cost_optimized
COST_PER_1K_TOKENS=0.002

# Context Management
MAX_CONTEXT_LENGTH=128000
CONTEXT_COMPRESSION_THRESHOLD=0.8
ENABLE_CONTEXT_COMPRESSION=true
ENABLE_LONG_CONTEXT=true

# Streaming
ENABLE_STREAMING=true
STREAM_CHUNK_SIZE=512

# Caching
ENABLE_RESPONSE_CACHE=true
CACHE_ENABLED_MODELS=["gpt-3.5-turbo", "claude-3-haiku"]
CACHE_TTL=3600

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_TOKENS_PER_MINUTE=90000

# Monitoring
ENABLE_TRACING=true
JAEGER_HOST=localhost
JAEGER_PORT=6831
ENABLE_METRICS=true
METRICS_PORT=9002

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=

# Security
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Feature Flags
ENABLE_FUNCTION_CALLING=true
ENABLE_CODE_INTERPRETER=false
ENABLE_WEB_SEARCH=false
ENABLE_PLUGINS=true
