  "components": {
    "schemas": {
      "AnimationCreate": {
        "properties": {
          "name": {
            "type": "string",
            "title": "Name",
            "description": "Animation name"
          },
          "description": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Description",
            "description": "Animation description"
          },
          "category": {
            "type": "string",
            "title": "Category",
            "description": "Animation category",
            "default": "movement"
          },
          "duration": {
            "type": "number",
            "exclusiveMinimum": 0.0,
            "title": "Duration",
            "description": "Animation duration"
          },
          "loop": {
            "type": "boolean",
            "title": "Loop",
            "description": "Whether animation loops",
            "default": false
          },
          "root_motion": {
            "type": "boolean",
            "title": "Root Motion",
            "description": "Whether animation has root motion",
            "default": false
          },
          "blend_in_time": {
            "type": "number",
            "minimum": 0.0,
            "title": "Blend In Time",
            "description": "Blend in time",
            "default": 0.1
          },
          "blend_out_time": {
            "type": "number",
            "minimum": 0.0,
            "title": "Blend Out Time",
            "description": "Blend out time",
            "default": 0.1
          },
          "tags": {
            "anyOf": [
              {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Tags",
            "description": "Animation tags"
          },
          "asset_url": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Asset Url",
            "description": "Animation asset URL"
          }
        },
        "type": "object",
        "required": [
          "name",
          "duration"
        ],
        "title": "AnimationCreate",
        "description": "Animation creation model"
      },
      "AnimationGraph": {
        "properties": {
          "graph_id": {
            "type": "string",
            "title": "Graph Id",
            "description": "Graph ID"
          },
          "character_id": {
            "type": "string",
            "title": "Character Id",
            "description": "Character ID"
          },
          "name": {
            "type": "string",
            "title": "Name",
            "description": "Graph name"
          },
          "states": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "States",
            "description": "State IDs in graph"
          },
          "default_state": {
            "type": "string",
            "title": "Default State",
            "description": "Default state ID"
          },
          "parameters": {
            "type": "object",
            "title": "Parameters",
            "description": "Graph parameters"
          },
          "is_active": {
            "type": "boolean",
            "title": "Is Active",
            "description": "Whether graph is active",
            "default": true
          }
        },
        "type": "object",
        "required": [
          "graph_id",
          "character_id",
          "name",
          "default_state"
        ],
        "title": "AnimationGraph",
        "description": "Animation graph model"
      },
      "AnimationRequest": {
        "properties": {
          "character_id": {
            "type": "string",
            "title": "Character Id",
            "description": "Character ID"
          },
          "user_id": {
            "type": "string",
            "title": "User Id",
            "description": "User ID"
          },
          "clip_id": {
            "type": "string",
            "title": "Clip Id",
            "description": "Animation clip ID"
          },
          "loop": {
            "type": "boolean",
            "title": "Loop",
            "description": "Whether to loop",
            "default": false
          },
          "speed": {
            "type": "number",
            "exclusiveMinimum": 0.0,
            "title": "Speed",
            "description": "Playback speed",
            "default": 1.0
          },
          "transition_duration": {
            "type": "number",
            "minimum": 0.0,
            "title": "Transition Duration",
            "description": "Transition duration",
            "default": 0.2
          }
        },
        "type": "object",
        "required": [
          "character_id",
          "user_id",
          "clip_id"
        ],
        "title": "AnimationRequest",
        "description": "Animation playback request"
      },
      "AnimationState": {
        "properties": {
          "state_id": {
            "type": "string",
            "title": "State Id",
            "description": "State ID"
          },
          "name": {
            "type": "string",
            "title": "Name",
            "description": "State name"
          },
          "default_clip": {
            "type": "string",
            "title": "Default Clip",
            "description": "Default animation clip ID"
          },
          "clips": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Clips",
            "description": "Available animation clips"
          },
          "transitions": {
            "additionalProperties": {
              "type": "string"
            },
            "type": "object",
            "title": "Transitions",
            "description": "Transitions to other states"
          },
          "exit_time": {
            "type": "number",
            "minimum": 0.0,
            "title": "Exit Time",
            "description": "Exit time for transitions",
            "default": 0.0
          },
          "can_interrupt": {
            "type": "boolean",
            "title": "Can Interrupt",
            "description": "Whether state can be interrupted",
            "default": true
          },
          "priority": {
            "type": "integer",
            "title": "Priority",
            "description": "State priority (higher = more important)",
            "default": 0
          }
        },
        "type": "object",
        "required": [
          "state_id",
          "name",
          "default_clip"
        ],
        "title": "AnimationState",
        "description": "Animation state model"
      },
      "BlendShape": {
        "properties": {
          "shape_id": {
            "type": "string",
            "title": "Shape Id",
            "description": "Shape ID"
          },
          "name": {
            "type": "string",
            "title": "Name",
            "description": "Shape name"
          },
          "category": {
            "type": "string",
            "title": "Category",
            "description": "Shape category: facial, body",
            "default": "facial"
          },
          "index": {
            "type": "integer",
            "title": "Index",
            "description": "Shape index"
          },
          "default_value": {
            "type": "number",
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Default Value",
            "description": "Default value",
            "default": 0.0
          },
          "range": {
            "items": {},
            "type": "array",
            "title": "Range",
            "description": "Value range",
            "default": [
              0.0,
              1.0
            ]
          }
        },
        "type": "object",
        "required": [
          "shape_id",
          "name",
          "index"
        ],
        "title": "BlendShape",
        "description": "Blend shape model"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}