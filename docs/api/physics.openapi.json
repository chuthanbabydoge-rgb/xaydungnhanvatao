  "components": {
    "schemas": {
      "ForceApplication": {
        "properties": {
          "body_id": {
            "type": "string",
            "title": "Body Id",
            "description": "Body ID"
          },
          "force": {
            "additionalProperties": {
              "type": "number"
            },
            "type": "object",
            "title": "Force",
            "description": "Force vector (x, y, z)"
          },
          "position": {
            "anyOf": [
              {
                "additionalProperties": {
                  "type": "number"
                },
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Position",
            "description": "Application point"
          },
          "duration": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Duration",
            "description": "Duration in seconds (None for impulse)"
          }
        },
        "type": "object",
        "required": [
          "body_id",
          "force"
        ],
        "title": "ForceApplication",
        "description": "Force application model"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
