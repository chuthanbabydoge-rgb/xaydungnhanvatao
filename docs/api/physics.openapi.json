            "additionalProperties": {
              "type": "number"
            },
            "type": "object",
            "title": "Collision Params",
            "description": "Collision shape parameters"
          },
          "friction": {
            "type": "number",
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Friction",
            "description": "Friction coefficient",
            "default": 0.5
          },
          "restitution": {
            "type": "number",
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Restitution",
            "description": "Restitution (bounciness)",
            "default": 0.0
          },
          "is_active": {
            "type": "boolean",
            "title": "Is Active",
            "description": "Whether body is active",
            "default": true
          }
        },
        "type": "object",
        "required": [
          "body_id",
          "object_id",
          "position"
        ],
        "title": "PhysicsBody",
        "description": "Physics body model"
      },
      "PhysicsSimulation": {
        "properties": {
          "simulation_id": {
            "type": "string",
            "title": "Simulation Id",
            "description": "Simulation ID"
          },
          "environment_id": {
            "type": "string",
            "title": "Environment Id",
            "description": "Environment ID"
          },
          "gravity": {
            "additionalProperties": {
              "type": "number"
            },
            "type": "object",
            "title": "Gravity",
            "description": "Gravity vector"
          },
          "time_step": {
            "type": "number",
            "exclusiveMinimum": 0.0,
            "title": "Time Step",
            "description": "Time step in seconds",
            "default": 0.016
