          "sub_steps": {
            "type": "integer",
            "minimum": 1.0,
            "title": "Sub Steps",
            "description": "Sub-steps for stability",
            "default": 1
          },
          "is_running": {
            "type": "boolean",
            "title": "Is Running",
            "description": "Whether simulation is running",
            "default": false
