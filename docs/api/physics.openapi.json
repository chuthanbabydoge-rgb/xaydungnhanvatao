        "title": "RaycastQuery",
        "description": "Raycast query model"
      },
      "RaycastResult": {
        "properties": {
          "hit": {
            "type": "boolean",
            "title": "Hit",
            "description": "Whether ray hit anything"
          },
          "body_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Body Id",
            "description": "Hit body ID"
          },
          "hit_point": {
            "anyOf": [
              {
                "additionalProperties": {
                  "type": "number"
                },
                "type": "object"
              },
              {
                "type": "null"
              }
