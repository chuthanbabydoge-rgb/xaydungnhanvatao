            "type": "string",
            "title": "Body Id",
            "description": "Body ID"
          },
          "object_id": {
            "type": "string",
            "title": "Object Id",
            "description": "Associated object ID"
          },
          "body_type": {
            "type": "string",
            "title": "Body Type",
            "description": "Body type: static, dynamic, kinematic",
            "default": "dynamic"
          },
          "mass": {
            "type": "number",
            "exclusiveMinimum": 0.0,
            "title": "Mass",
            "description": "Body mass in kg",
            "default": 1.0
          },
          "position": {
            "additionalProperties": {
              "type": "number"
            },
            "type": "object",
            "title": "Position",
            "description": "Position (x, y, z)"
          },
          "rotation": {
            "additionalProperties": {
              "type": "number"
            },
            "type": "object",
            "title": "Rotation",
            "description": "Rotation (x, y, z)"
          },
          "velocity": {
            "additionalProperties": {
              "type": "number"
            },
            "type": "object",
            "title": "Velocity",
            "description": "Velocity (x, y, z)"
          },
          "angular_velocity": {
            "additionalProperties": {
              "type": "number"
            },
            "type": "object",
            "title": "Angular Velocity",
            "description": "Angular velocity"
          },
          "collision_shape": {
            "type": "string",
