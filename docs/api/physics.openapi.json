        "description": "Physics simulation model"
      },
      "PhysicsState": {
        "properties": {
          "body_id": {
            "type": "string",
            "title": "Body Id",
            "description": "Body ID"
          },
          "position": {
            "additionalProperties": {
              "type": "number"
            },
            "type": "object",
            "title": "Position",
            "description": "Current position"
          },
          "rotation": {
            "additionalProperties": {
              "type": "number"
            },
            "type": "object",
            "title": "Rotation",
            "description": "Current rotation"
          },
          "velocity": {
            "additionalProperties": {
              "type": "number"
            },
            "type": "object",
            "title": "Velocity",
            "description": "Current velocity"
          },
          "angular_velocity": {
            "additionalProperties": {
              "type": "number"
            },
            "type": "object",
            "title": "Angular Velocity",
            "description": "Current angular velocity"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "title": "Timestamp",
            "description": "State timestamp"
