          "direction": {
            "additionalProperties": {
              "type": "number"
            },
            "type": "object",
            "title": "Direction",
            "description": "Ray direction (normalized)"
          },
          "max_distance": {
            "type": "number",
            "exclusiveMinimum": 0.0,
            "title": "Max Distance",
            "description": "Maximum ray distance",
            "default": 100.0
