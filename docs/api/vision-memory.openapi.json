{
  "openapi": "3.1.0",
  "info": {
    "title": "Vision Memory Service",
    "description": "Visual observation, visual memory storage, and visual recognition for AI Companion",
    "version": "1.0.0"
  },
  "paths": {
    "/api/v1/vision/observe": {
      "post": {
        "summary": "Record Observation",
        "description": "Record a visual observation",
        "operationId": "record_observation_api_v1_vision_observe_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VisualObservation"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/vision/recognize": {
      "post": {
        "summary": "Recognize Visual",
        "description": "Perform visual recognition",
        "operationId": "recognize_visual_api_v1_vision_recognize_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VisualRecognitionRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/vision/recall": {
      "post": {
        "summary": "Recall Visual",
        "description": "Recall visual memory",
        "operationId": "recall_visual_api_v1_vision_recall_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VisualRecallRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/vision/memories/{user_id}": {
      "get": {
        "summary": "Get Visual Memories",
        "description": "Get visual memories for a user",
        "operationId": "get_visual_memories_api_v1_vision_memories__user_id__get",
        "parameters": [
          {
            "name": "user_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "User Id"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 20,
              "title": "Limit"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/vision/memories/{user_id}/objects/{object_name}": {
      "get": {
        "summary": "Get Memories By Object",
        "description": "Get visual memories by object name",
        "operationId": "get_memories_by_object_api_v1_vision_memories__user_id__objects__object_name__get",
        "parameters": [
          {
            "name": "user_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "User Id"
            }
          },
          {
            "name": "object_name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Object Name"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "summary": "Health Check",
        "description": "Health check endpoint",
        "operationId": "health_check_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      },
      "VisualObservation": {
        "properties": {
          "observation_id": {
            "type": "string",
            "title": "Observation Id"
          },
          "user_id": {
            "type": "string",
            "title": "User Id",
            "description": "User ID"
          },
          "image_data": {
            "type": "string",
            "title": "Image Data",
            "description": "Base64 encoded image data"
          },
          "position": {
            "anyOf": [
              {
                "additionalProperties": {
                  "type": "number"
                },
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Position",
            "description": "3D position coordinates"
          },
          "rotation": {
            "anyOf": [
              {
                "additionalProperties": {
                  "type": "number"
                },
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Rotation",
            "description": "Rotation coordinates"
          },
          "timestamp": {
            "type": "string",
            "title": "Timestamp"
          }
        },
        "type": "object",
        "required": [
          "user_id",
          "image_data"
        ],
        "title": "VisualObservation",
        "description": "Visual observation model"
      },
      "VisualRecallRequest": {
        "properties": {
          "user_id": {
            "type": "string",
            "title": "User Id",
            "description": "User ID"
          },
          "object_name": {
            "type": "string",
            "title": "Object Name",
            "description": "Object name to recall"
          },
          "time_threshold": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Time Threshold",
            "description": "Time threshold in seconds (default 24 hours)",
            "default": 86400
          }
        },
        "type": "object",
        "required": [
          "user_id",
          "object_name"
        ],
        "title": "VisualRecallRequest",
        "description": "Visual recall request"
      },
      "VisualRecognitionRequest": {
        "properties": {
          "user_id": {
            "type": "string",
            "title": "User Id",
            "description": "User ID"
          },
          "image_data": {
            "type": "string",
            "title": "Image Data",
            "description": "Base64 encoded image data"
          },
          "recognition_type": {
            "type": "string",
            "title": "Recognition Type",
            "description": "Type of recognition: objects, person, location"
          }
        },
        "type": "object",
        "required": [
          "user_id",
          "image_data",
          "recognition_type"
        ],
        "title": "VisualRecognitionRequest",
        "description": "Visual recognition request"
      }
    }
  }
}