            "maximum": 20.0,
            "minimum": 6.0,
            "title": "Breathing Rate",
            "description": "Breaths per minute",
            "default": 12.0
          },
          "breath_depth": {
            "type": "number",
            "maximum": 1.0,
            "minimum": 0.1,
            "title": "Breath Depth",
